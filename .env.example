# Copy this file to .env and replace the placeholder with your real key.
# .env is gitignored — it never gets committed.
#
# Get your key at https://platform.openai.com/api-keys
#
# Security note (POC scope):
# The key is injected into the backend container's runtime environment.
# It is NOT baked into any image layer, and .env is excluded from the
# build context via .dockerignore. However, anyone with shell access
# to the running container (docker exec grocery-sop-backend env) or the
# Docker socket (docker inspect grocery-sop-backend) can read it. That
# is acceptable for a local POC; a real deployment should load the key
# from a secrets manager (AWS Secrets Manager, Azure Key Vault, Vault)
# at process start instead of the environment.

OPENAI_API_KEY=sk-...
